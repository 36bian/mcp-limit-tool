{
  "exa": {
    "command": "npx",
    "args": ["-y", "exa-mcp-server"],
    "env": {
      "EXA_API_KEY": "your_api_key"
    },
    "allowed_tools": [],
    "rate_limits": {
      "monthly": {"total": 2000, "duration": "30d"}
    }
  },
  "jina": {
    "command": "npx",
    "args": ["-y", "jina-ai-mcp-server"],
    "env": {
      "JINA_API_KEY": "your_api_key"
    },
    "allowed_tools": ["search_web", "read_webpage"],
    "rate_limits": {}
  },
  "github": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "your_api_key"
    },
    "allowed_tools": ["search_repositories", "get_file_contents", "search_code"],
    "rate_limits": {
      "hourly": {"total": 5000, "duration": "1h"}
    }
  }
}
